# ===========================================
# HireSense AI — Environment Configuration
# Copy this file to .env and fill in real values.
# Never commit your actual .env file.
# ===========================================

# --- Flask ---
FLASK_ENV=production
FLASK_APP=wsgi.py
SECRET_KEY=change-this-to-a-long-random-string
HOST=0.0.0.0
PORT=5000
DEBUG=False

# --- Gemini API (for resume improvement suggestions) ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# --- Embedding model ---
# Any sentence-transformers model name works; this one is a strong
# general-purpose default with a good speed/quality tradeoff.
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# --- FAISS index ---
FAISS_INDEX_PATH=data/faiss_index/resumes.index
FAISS_METADATA_PATH=data/faiss_index/metadata.json
FAISS_INDEX_TYPE=flat

# --- Resume corpus used to (re)build the FAISS index ---
RESUME_CORPUS_PATH=data/sample_resumes.csv

# --- Upload constraints ---
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,docx,txt

# --- Rate limiting ---
RATE_LIMIT_DEFAULT=60 per minute
RATE_LIMIT_MATCH=10 per minute

# --- Caching ---
CACHE_DIR=.cache
CACHE_TTL_SECONDS=3600

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
